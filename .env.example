# LLM (script + title generation) — pick one
GROQ_API_KEY=
GEMINI_API_KEY=

# TTS
# Edge TTS needs no key. If using ElevenLabs/Sarvam instead, set this:
ELEVENLABS_API_KEY=

# YouTube Data API (OAuth client, generated via Google Cloud Console)
YT_CLIENT_SECRETS_FILE=client_secret.json
YT_TOKEN_FILE=token.json

# Shop identity — used in every script's CTA
SHOP_NAME=Your Shop Name
SHOP_LOCATION=Biraul
SHOP_CONTACT=+91-XXXXXXXXXX
SHOP_CTA=Visit us at {SHOP_NAME}, {SHOP_LOCATION} or call {SHOP_CONTACT}

# How many videos to publish per day
VIDEOS_PER_DAY=3

# Local paths
MEDIA_LIBRARY_DIR=./media_library
OUTPUT_DIR=./output
DB_PATH=./pipeline.db
YOUTUBE_API_KEY=
SHOP_LOGO_PATH=assets/logo.png
